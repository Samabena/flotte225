{% extends "base.html.j2" %}

{% block title %}Rapport conducteur — {{ driver.full_name }}{% endblock %}
{% block title_h1 %}Rapport conducteur — {{ driver.full_name }}{% endblock %}

{% block content %}

  <h2>Identité du conducteur</h2>
  <table>
    <tbody>
      <tr><td style="width: 30%;"><strong>Nom complet</strong></td><td>{{ driver.full_name }}</td></tr>
      <tr><td><strong>Identifiant</strong></td><td>{{ driver.username or '—' }}</td></tr>
      <tr><td><strong>Téléphone</strong></td><td>{{ driver.phone or '—' }}</td></tr>
      <tr>
        <td><strong>Statut</strong></td>
        <td>
          {% if driver.is_disabled %}
            <span class="badge badge-muted">Désactivé</span>
          {% elif driver.driving_status %}
            <span class="badge badge-ok">En conduite</span>
          {% else %}
            <span class="badge badge-muted">Disponible</span>
          {% endif %}
        </td>
      </tr>
    </tbody>
  </table>

  <h2>Synthèse de la période</h2>
  <div class="kpi-grid">
    <div class="kpi">
      <div class="label">Dépense totale</div>
      <div class="value">{{ totals.total_spend_fcfa | format_fcfa }}</div>
      <div class="sub">{{ totals.entries_count }} plein{{ 's' if totals.entries_count > 1 else '' }}</div>
    </div>
    <div class="kpi">
      <div class="label">Litres consommés</div>
      <div class="value">{{ totals.total_litres | format_number(2) }} L</div>
      <div class="sub">moy. {{ totals.avg_litres_per_entry | format_number(2) }} L / plein</div>
    </div>
    <div class="kpi">
      <div class="label">Distance parcourue</div>
      <div class="value">{{ totals.total_km | format_number(0) }} km</div>
      <div class="sub">sur la période</div>
    </div>
    <div class="kpi">
      <div class="label">Consommation moyenne</div>
      <div class="value">
        {% if totals.avg_consumption %}{{ totals.avg_consumption | format_number(2) }} L/100km{% else %}—{% endif %}
      </div>
      <div class="sub">tous véhicules confondus</div>
    </div>
    <div class="kpi">
      <div class="label">Coût moyen / km</div>
      <div class="value">{{ totals.cost_per_km | format_fcfa }}</div>
      <div class="sub">indicateur d'efficacité</div>
    </div>
    <div class="kpi">
      <div class="label">Véhicules conduits</div>
      <div class="value">{{ vehicles_driven | length }}</div>
      <div class="sub">distincts sur la période</div>
    </div>
  </div>

  <h2>Véhicules conduits</h2>
  {% if vehicles_driven %}
    <table>
      <thead>
        <tr>
          <th>Véhicule</th>
          <th class="num">Pleins</th>
          <th class="num">Dépense (FCFA)</th>
          <th class="num">Litres</th>
          <th class="num">Distance (km)</th>
        </tr>
      </thead>
      <tbody>
        {% for v in vehicles_driven %}
        <tr>
          <td>{{ v.name }}</td>
          <td class="num">{{ v.entries }}</td>
          <td class="num">{{ v.spend_fcfa | format_fcfa }}</td>
          <td class="num">{{ v.litres | format_number(2) }}</td>
          <td class="num">{{ v.distance_km | format_number(0) }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <p class="empty">Aucun véhicule conduit sur la période.</p>
  {% endif %}

  <h2>Détail des pleins</h2>
  {% if entries %}
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Véhicule</th>
          <th class="num">Odomètre</th>
          <th class="num">Litres</th>
          <th class="num">Montant (FCFA)</th>
          <th class="num">L/100km</th>
        </tr>
      </thead>
      <tbody>
        {% for e in entries %}
        <tr>
          <td>{{ e.date }}</td>
          <td>{{ e.vehicle_name }}</td>
          <td class="num">{{ e.odometer_km | format_number(0) }}</td>
          <td class="num">{{ e.litres | format_number(2) }}</td>
          <td class="num">{{ e.amount_fcfa | format_fcfa }}</td>
          <td class="num">{% if e.consumption %}{{ e.consumption | format_number(2) }}{% else %}—{% endif %}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  {% else %}
    <p class="empty">Aucun plein enregistré sur la période.</p>
  {% endif %}

{% endblock %}
